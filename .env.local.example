// .env.local.example - Copy to .env.local and fill with YOUR values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: supabase.com → Your Project → Settings → API

# Your Supabase project URL
# Example: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, safe to share)
# Found under "PROJECT API KEYS" → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (SECRET - never commit this!)
# Found under "PROJECT API KEYS" → "service_role secret"
# ⚠️ KEEP THIS SECRET ⚠️
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ============================================
# ENCRYPTION & SECURITY
# ============================================

# AES-256-GCM Encryption Key (must be exactly 32 bytes when decoded from base64)
# Generate with: openssl rand -base64 32
# This encrypts all submissions at rest in the database
# ⚠️ KEEP THIS SECRET - rotate periodically ⚠️
ENCRYPTION_KEY=YOUR_BASE64_32_BYTE_KEY_HERE

# Rate Limiting Salt (must be 256-bit hex)
# Generate with: openssl rand -hex 32
# Changes daily for rotating IP hashes
# This prevents IP correlation attacks
RATE_LIMIT_SALT_INITIAL=YOUR_HEX_32_BYTE_SALT_HERE


# ============================================
# AI MODERATION (OPTIONAL)
# ============================================

# OpenAI API Key for advanced content moderation
# Get from: platform.openai.com/account/api-keys
# Leave empty to use keyword-based moderation only
OPENAI_API_KEY=sk-your-api-key-here


# ============================================
# ENVIRONMENT & LOGGING
# ============================================

# Node environment (development/production)
NODE_ENV=development

# Log level (debug/info/warn/error)
NEXT_PUBLIC_LOG_LEVEL=debug

# Request logging (disable for privacy in production)
ENABLE_REQUEST_LOGS=false

# Analytics and telemetry (disable for privacy)
DISABLE_ANALYTICS=true
DISABLE_TELEMETRY=true


# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_REACTIONS=true
ENABLE_FEED=true

# Content validation limits
MAX_SUBMISSION_LENGTH=5000
MIN_SUBMISSION_LENGTH=10
