# Privacy-First Platform - Environment Configuration
# NEVER commit .env.local - this is .env.example only

# Supabase Configuration
# Get these from https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption Keys (generate with: openssl rand -base64 32)
# CRITICAL: Rotate these regularly
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Rate Limiting Salt (rotates daily in code)
# Generate with: openssl rand -hex 32
RATE_LIMIT_SALT_INITIAL=your-hex-32-byte-salt

# AI Moderation (optional)
# If using OpenAI: sk-xxx...
OPENAI_API_KEY=

# Environment
NODE_ENV=production
NEXT_PUBLIC_LOG_LEVEL=error

# Security
ENABLE_REQUEST_LOGS=false
DISABLE_ANALYTICS=true
DISABLE_TELEMETRY=true

# Features
ENABLE_REACTIONS=true
ENABLE_FEED=true
MAX_SUBMISSION_LENGTH=5000
MIN_SUBMISSION_LENGTH=10
